{
  "version": 2,
  "builds": [
    {
  "src": "app.py",
  "use": "@vercel/python",
  "config": {
    "maxLambdaSize": "150mb",
    "pythonVersion": "3.11"
  }
}
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "buildCommand": "pip install -r requirements.txt",
  "installCommand": "pip install -r requirements.txt"
}
